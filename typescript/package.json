{
  "name": "libpetri",
  "version": "1.8.3",
  "description": "Coloured Time Petri Net engine — TypeScript port",
  "homepage": "https://libpetri.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/debe/libpetri.git",
    "directory": "typescript"
  },
  "bugs": {
    "url": "https://github.com/debe/libpetri/issues"
  },
  "license": "Apache-2.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./export": {
      "import": "./dist/export/index.js",
      "types": "./dist/export/index.d.ts"
    },
    "./verification": {
      "node": {
        "import": "./dist/verification/index.js",
        "types": "./dist/verification/index.d.ts"
      }
    },
    "./debug": {
      "node": {
        "import": "./dist/debug/index.js",
        "types": "./dist/debug/index.d.ts"
      }
    },
    "./doclet": {
      "node": {
        "import": "./dist/doclet/index.js",
        "types": "./dist/doclet/index.d.ts"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench",
    "docs": "typedoc"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@viz-js/viz": "^3.25.0",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@viz-js/viz": ">=3.0.0",
    "typedoc": ">=0.27.0"
  },
  "peerDependenciesMeta": {
    "typedoc": {
      "optional": true
    },
    "@viz-js/viz": {
      "optional": true
    }
  },
  "dependencies": {
    "z3-solver": "^4.16.0"
  }
}
