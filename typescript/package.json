{
  "name": "libpetri",
  "version": "0.3.3",
  "description": "Coloured Time Petri Net engine — TypeScript port",
  "homepage": "https://libpetri.org",
  "repository": {
    "type": "git",
    "url": "https://github.com/debe/libpetri.git",
    "directory": "typescript"
  },
  "bugs": {
    "url": "https://github.com/debe/libpetri/issues"
  },
  "license": "Apache-2.0",
  "files": ["dist"],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./export": {
      "import": "./dist/export/index.js",
      "types": "./dist/export/index.d.ts"
    },
    "./verification": {
      "node": {
        "import": "./dist/verification/index.js",
        "types": "./dist/verification/index.d.ts"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.4.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "z3-solver": "^4.13.4"
  }
}
