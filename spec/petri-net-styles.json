    "end":         { "shape": "circle",  "fill": "#cce5ff", "stroke": "#004085", "penwidth": 2.0, "width": 0.35 },
    "environment": { "shape": "circle",  "fill": "#f8d7da", "stroke": "#721c24", "penwidth": 2.0, "style": "dashed", "width": 0.35 },
